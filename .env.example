# SmartBooks — Variables de entorno (copia a backend/.env y ajusta los valores)

# PostgreSQL
POSTGRES_DB=smartbooks
POSTGRES_USER=smartbooks
POSTGRES_PASSWORD=smartbooks_password

# Backend (Next.js)
DATABASE_URL=postgresql://smartbooks:smartbooks_password@postgres:5432/smartbooks
JWT_SECRET=cambia-esto-por-un-secreto-seguro-de-al-menos-32-caracteres
ML_SERVICE_URL=http://ml-service:8000
FRONTEND_URL=http://localhost:3000
#NODE_ENV=production

# MinIO (almacenamiento de imágenes)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=smartbooks-covers

# ML Service
DATABASE_URL=postgresql://smartbooks:smartbooks_password@postgres:5432/smartbooks

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
